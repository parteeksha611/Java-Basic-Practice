class ConvertFarenheitToCelsius {
    
    double farenheit = 100;
    double res = 0;
    
    public static void main(String[] args) {
        ConvertFarenheitToCelsius st = new ConvertFarenheitToCelsius();
        st.convertFromFarenheitToCelsius();
    }
    
    // Convert from celsius to farenheit
    public void convertFromFarenheitToCelsius(){
        res = (farenheit-32)*5/9;
       System.out.println(farenheit+" Farenheit is "+res+" Celsius");
    }
}
