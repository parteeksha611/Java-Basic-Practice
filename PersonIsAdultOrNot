class AgeMakesAdult {
    
    int age = 38;
    
    public static void main(String[] args) {
        AgeMakesAdult st = new AgeMakesAdult();
        st.checkIfPersonIsAdult(st.age);
    }
    
    // Check if given person age is adult
    public void checkIfPersonIsAdult(int age){
       if(age>=18){
           System.out.println(age+" -> Person is adult.");
       }
       else if(age<0){
            System.out.println(age+" -> Invalid Input");
       }
       else{
            System.out.println(age+" -> Person is not adult.");
       }
    }
}
