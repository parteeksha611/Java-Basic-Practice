class evenOdd {
    
    int num = 1;
    
    public static void main(String[] args) {
        evenOdd eo = new evenOdd();
        eo.evenOdd(eo.num);
    }
    
    // Find the word is even Or odd
    
    public void evenOdd( int num){
        for(int i=0; i<100; i++){
        if(num%2==0){
            System.out.println("This number is even -> "+num);
        }
        else{
             System.out.println("This number is odd  -> "+num);
        }
        num++;
        }
        
    }
}
