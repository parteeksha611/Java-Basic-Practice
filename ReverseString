class ReverseString {
    
    String str = "Automation";
    String res = "";
    
    public static void main(String[] args) {
        ReverseString rs = new ReverseString();
        rs.reverseString();
    }
    
    // Reverse String
    public void reverseString(){
       for(int i=0; i<str.length(); i++){
            res = str.charAt(i)+res;
       }
       System.out.println(res);
    }
}
