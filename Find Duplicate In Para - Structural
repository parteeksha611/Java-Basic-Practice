import java.util.HashMap;
import java.util.Arrays;
import java.util.List;
import java.util.ArrayList;
import java.util.Map;
class Main {
    
    String paragraph = "Test 1 test 1 1 test 7 test 7 tst test 1 77 7 test test ";
    
    public static void main(String[] args) {
      Main m = new Main();

      m.printRepeatedWords(
      (m.getMapValues
      (m.getWordOccurrenceMap
      (m.getWordsFromParagraph 
      (m.paragraph)))));
    }
    
    private String[] getWordsFromParagraph (String paragraph) {
        paragraph.toLowerCase();
        String para[] = paragraph.split("\\W+");
        return para;
    }
    
    private HashMap<String, Integer> getWordOccurrenceMap(String[] words) {
        HashMap<String, Integer> map = new HashMap<>();
        for(int i=0; i<words.length; i++){
        map.put(words[i], map.getOrDefault(words[i], 0)+1);
        }
        return map;
    }
    
    public List <Map.Entry<String, Integer>> getMapValues(HashMap<String, Integer> map){
        List <Map.Entry<String, Integer>> list = new ArrayList<>();
        for(Map.Entry<String, Integer> set:map.entrySet()){
            if(set.getValue()>1){
                list.add(set);
            }
        }
        list.sort(Map.Entry.comparingByValue());
        list = list.reversed();
        return list;
    }
    
    public void printRepeatedWords( List<Map.Entry<String, Integer>>  list){
        for(Map.Entry<String, Integer>repeatedWords: list){
            if(repeatedWords.getValue()>1){
                System.out.println("Repated Word is "+repeatedWords.getKey()+ ". It is repeated "+repeatedWords.getValue()+ " times.");
            }
        }
    }
    // printWordOccurrenceMap
}
