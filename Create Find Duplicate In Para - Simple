import java.util.HashMap;
import java.util.Arrays;
import java.util.List;
import java.util.ArrayList;
import java.util.Map;
class RepeatedWords {
    
   String test = "Test 1 test 1 1 test 7 test 7 tst test 1 77 7";
   
    public static void main (String a[]){
       RepeatedWords dp = new RepeatedWords();
       dp.findRepeatedWords();
    }
    
public void findRepeatedWords() {
    test = test.toLowerCase();
    String testarr[] = test.split("\\W+");
    int count = 0;

    HashMap<String,Integer> hm = new HashMap<>();
    for(int i=0; i<testarr.length; i++){
        hm.put(testarr[i], hm.getOrDefault(testarr[i], 0) + 1);
    }

    List<Map.Entry<String, Integer>> list = new ArrayList<>();
    for(Map.Entry<String,Integer> entry: hm.entrySet()){
        if(entry.getValue() > 1){
            list.add(entry);
        }
    }
    list.sort(Map.Entry.comparingByValue());
    list = list.reversed();
    for(Map.Entry<String, Integer> repeatedWords : list){
        if(count == 2) break; // Add only if wanted to print first two entries
    System.out.println(repeatedWords.getKey()+" Word is repeated "+repeatedWords.getValue() + " times");
    count++;
    }
}
}
