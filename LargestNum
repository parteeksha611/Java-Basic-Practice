class Main {
    
    int num[] = {2, 9, 8, 7, 4, 3, 1};
    int largestNum = 0;
    
    public static void main(String[] args) {
       Main m1 = new Main();
      System.out.println(m1.largestNumber(m1.num, m1.largestNum));
    }
    
    public int largestNumber(int num[], int largestNum){
        for(int i=0; i<num.length; i++){
            if(num[i]>largestNum){
                largestNum = num[i];
            }
        }
        return largestNum;
    }
}
