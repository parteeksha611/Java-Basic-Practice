class Main {
    
    int nums[] = {1, 3, 5, 8, 10, 32};
    int target = 8;
    
    public static void main(String[] args) {
        Main m = new Main();
       System.out.println(m.binarySearch(m.nums, m.target));
    }
    
    
    public int binarySearch(int[] nums, int target){
        int beg = 0;
        int end = nums.length - 1;

        while (beg <= end) {
            int mid = beg + (end - beg) / 2;

            if (nums[mid] == target) {
                return mid;
            } else if (nums[mid] < target) {
                beg = mid + 1;
            } else {
                end = mid - 1;
            }
        }
        return -1;
    }
}
