import java.util.*;
class Main {
    
    char[] sarr= {'h', 'e', 'L', 'L', 'o'};
    
    public static void main(String[] args) {
        Main m = new Main();
       m.reverseString(m.sarr);
    }

    public void reverseString(char[] sarr) {
        int length = sarr.length;
        int halfLength = length/2;

        for(int i=0; i<halfLength; i++){
            char temp = sarr[i];
            sarr[i] = sarr[length-1-i];
            sarr[length-1-i] = temp;
        }
        System.out.println(Arrays.toString(sarr));
    }
}
